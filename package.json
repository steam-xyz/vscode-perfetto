{
  "name": "vscode-perfetto",
  "displayName": "VSCode Perfetto",
  "description": "Open trace files in bundled Perfetto UI from VS Code.",
  "version": "0.0.4",
  "publisher": "allen",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist",
    "media",
    "perfetto-ui",
    "README.md"
  ],
  "activationEvents": [
    "onCommand:vscode-perfetto.openTrace",
    "onCommand:vscode-perfetto.showOutput"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vscode-perfetto.openTrace",
        "title": "Open in Perfetto",
        "category": "Perfetto"
      },
      {
        "command": "vscode-perfetto.showOutput",
        "title": "Show Output",
        "category": "Perfetto"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vscode-perfetto.openTrace",
          "when": "explorerResourceIsFolder == false && (resourceExtname == .json || resourceExtname == .chrom_trace || resourceExtname == .chrome_trace)",
          "group": "navigation@50"
        }
      ],
      "editor/context": [
        {
          "command": "vscode-perfetto.openTrace",
          "when": "resourceExtname == .json || resourceExtname == .chrom_trace || resourceExtname == .chrome_trace",
          "group": "navigation@50"
        }
      ]
    },
    "configuration": {
      "title": "Perfetto",
      "properties": {
        "perfetto.uiUrl": {
          "type": "string",
          "default": "",
          "description": "Optional Perfetto UI override URL. Leave empty to use the bundled UI."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "package:vsix": "vsce package --no-yarn --allow-missing-repository --skip-license",
    "test:e2e": "pnpm run compile && pnpm run compile:test && node ./dist/test/runTest.js",
    "perfetto:build:source": "./scripts/build-perfetto-ui-from-source.sh",
    "perfetto:fetch": "./scripts/fetch-perfetto-ui.sh"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "mocha": "^11.7.5",
    "typescript": "^5.9.2"
  }
}
